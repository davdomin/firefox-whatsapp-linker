{
  "manifest_version": 3,
  "name": "WhatsApp Quick Connect",
  "version": "1.0.0",
  "description": "Automatically detects phone numbers on web pages and converts them into clickable WhatsApp links.",
  "browser_specific_settings": {
    "gecko": {
      "id": "whatsapp-quick-connect@davdomin.dev",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": false
      }
    }
  },
  "icons": {
    "48": "assets/icon-48.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/phone-detector.js"]
    }
  ],
  "permissions": [
    "activeTab"
  ]
}
